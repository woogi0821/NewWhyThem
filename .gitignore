# Build Tools (Gradle / Maven)
# ==========================================
.gradle/
build/
target/
out/
!gradle/wrapper/gradle-wrapper.jar

# ==========================================
# IDE (IntelliJ IDEA & Eclipse)
# ==========================================
# 팀원들 각자의 에디터 설정이 깃허브에 올라가는 것을 막습니다.
.idea/
*.iml
*.iws
*.ipr

# 혹시 이클립스나 VSCode로 백엔드 켜는 팀원을 위한 방어막
.project
.classpath
.settings/
.factorypath
.springBeans
.sts4-cache/

# ==========================================
# OS Generated Files (맥/윈도우 찌꺼기 파일)
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# (기존의 Logs, Diagnostic reports, Runtime data... 항목들 생략)
# ... 중략 ...

# ==========================================
# Security & Config (위치 기반 API 키 등 보안)
# ==========================================
# 지도 API 키나 DB 비밀번호가 담긴 설정 파일은 절대 올라가면 안 됩니다.
*.properties
*.yml
# 단, 설정 샘플 파일은 예외로 두어 팀원들이 구조를 알게 합니다.
!application.example.yml
!application.example.properties

