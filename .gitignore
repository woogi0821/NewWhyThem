# ==========================================
# 🏢 IntelliJ & IDE (개인 설정 - 어떤 폴더에 있든 싹 다 무시)
# ==========================================
.idea/
**/.idea/
**/workspace.xml
**/tasks.xml
**/shelf/
*.iml
**/*.iml
*.iws
*.ipr

# 혹시 VSCode 쓰는 팀원을 위한 방어막
.vscode/
**/.vscode/

# ==========================================
# ☕ Backend (Spring Boot / Maven / Gradle)
# ==========================================
**/target/
**/build/
**/out/
**/*.class
**/*.jar
**/*.war
**/*.zip
**/*.tar.gz
!**/src/main/**/target/ 
# (위 설정은 혹시 모를 오작동 방지용)

# ==========================================
# ⚛️ Frontend (Node.js / React)
# ==========================================
**/node_modules/
**/dist/
.eslintcache
*.local
.env
.env.*.local

# ==========================================
# 💻 OS & Logs (운영체제 쓰레기 및 로그)
# ==========================================
**/*.log
.DS_Store
Thumbs.db
desktop.ini
# Gradle 임시 파일 및 잠금 파일 박멸
.gradle/
**/ .gradle/
*.lock

